# Copy this file to .env and fill in the keys you have.
# EVERY key is optional — with an empty .env the pipeline runs fully local/free
# (SD 1.5 images, AnimateDiff/Ken Burns motion, SadTalker lip-sync, edge-tts voice).
# Add a key and that stage automatically upgrades to the state-of-the-art cloud engine.

# ── fal.ai — Flux images + Kling image-to-video + Stable Audio music ──────────
# Sign up (free trial credits): https://fal.ai/dashboard/keys
# One key unlocks Flux (stills), Kling (cinematic action motion), and Stable Audio.
FAL_KEY=

# ── ElevenLabs — premium cinematic narration (+ word timestamps) ──────────────
# Free tier = 10,000 characters/month (a 30s script is ~500 chars).
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional: override the narrator voice (default = "Adam", deep male).
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# ── Hedra — Character-3 talking-photo lip-sync (speaking scenes) ──────────────
# Free tier = ~50 seconds/month (enough for one reel; output is watermarked).
# Get a key: https://www.hedra.com/  (Profile -> API)
HEDRA_API_KEY=

# ── Optional / legacy ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
REPLICATE_API_TOKEN=
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json
